# Binary files — prevent Git from mangling line endings or diffing
*.pdf binary
*.docx binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Large JSON data files — treat as binary for diff performance
explanations_cache.json binary
hazzard_chapters.json binary

# Force LF line endings for web/code files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts — must be LF for portability (Claude Code hooks + git hooks)
*.sh text eol=lf
scripts/git-hooks/pre-commit text eol=lf
